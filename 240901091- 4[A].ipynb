   "source": [
    "import pandas as pd\n",
    "data={\n",
    "    \"Electrode1\":[10,12,11,13,15],\n",
    "    \"Electrode2\":[8,9,10,9,11],\n",
    "    \"Electrode3\":[14,13,15,16,14]\n",
    "}\n",
    "df = pd.DataFrame(data)\n",
    "print(\"EEG Data:\\n\",df)\n",
    "\n",
    "print(\"\\nMean values:\\n\",df.mean())\n",
    "print(\"\\nVariance:\\n\",df.var())\n",
    "print(\"\\nPeak Values:\\n\",df.max())"
   ]
